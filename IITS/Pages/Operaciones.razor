        var id = Guid.NewGuid();
        Db.DeviceModels.Add(new IITS.Entities.DeviceModel { Id = id, ManufacturerId = manufId, Name = name });
        await Db.SaveChangesAsync();
        deviceModelsList = await Db.DeviceModels.AsNoTracking().Include(d => d.Manufacturer).OrderBy(d => d.Name).ToListAsync();
        formDeviceModelIdStr = id.ToString();
        CerrarAgregarModelo();
        Toast.ShowToast("Modelo agregado.", IITS.Services.ToastLevel.Success);
    }

    private void AbrirAgregarArea() { nuevoAreaNombre = ""; mostrarModalAgregarArea = true; }
    private void CerrarModalAgregarArea() { mostrarModalAgregarArea = false; nuevoAreaNombre = ""; }
