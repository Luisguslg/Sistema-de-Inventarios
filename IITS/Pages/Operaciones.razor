    private void CerrarModal() { mostrarModal = false; editingId = null; }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(formHostname)) { Toast.ShowToast("Hostname requerido", IITS.Services.ToastLevel.Warning); return; }
        var esVirtual = !string.IsNullOrWhiteSpace(formTipoInfraestructura) && formTipoInfraestructura.Trim().Contains("Virtual", StringComparison.OrdinalIgnoreCase);
        if (esVirtual && string.IsNullOrWhiteSpace(formHost)) { Toast.ShowToast("Host es requerido cuando el tipo de infraestructura es Virtual.", IITS.Services.ToastLevel.Warning); return; }
        var esFisico = formTipoInfraestructura?.Trim().Equals("Físico", StringComparison.OrdinalIgnoreCase) == true;
        if (esFisico && string.IsNullOrWhiteSpace(formSerial?.Trim())) { Toast.ShowToast("Serial es obligatorio cuando el dispositivo es físico.", IITS.Services.ToastLevel.Warning); return; }
        if (!string.IsNullOrWhiteSpace(formIP))
        {
            var ip = formIP.Trim();
            if (!System.Text.RegularExpressions.Regex.IsMatch(ip, @"^([0-9]{1,3}\.){3}[0-9]{1,3}$") && !System.Text.RegularExpressions.Regex.IsMatch(ip, @"^[a-fA-F0-9:]+$"))
            { Toast.ShowToast("El campo IP no tiene un formato válido (ej. 192.168.1.10 o IPv6).", IITS.Services.ToastLevel.Warning); return; }
        }
        if (!Guid.TryParse(formEstatusIdStr, out var eid)) return;
        var hostname = formHostname.Trim();
        if (hostname.Contains("\n") || hostname.Contains("\r") || hostname.Length > 200)
        { Toast.ShowToast("Hostname no debe contener saltos de línea y debe ser menor a 200 caracteres.", IITS.Services.ToastLevel.Warning); return; }
        var serial = formSerial?.Trim() ?? "";
        var garantiaExpira = formGarantiaExpira;
        Guid? officeId = Guid.TryParse(formOfficeIdStr, out var oid) ? oid : null;
        Guid? areaId = Guid.TryParse(formAreaIdStr, out var aid) ? aid : null;
        Guid? alojamientoId = Guid.TryParse(formAlojamientoIdStr, out var alid) ? alid : null;
        Guid? ownerAreaId = Guid.TryParse(formOwnerAreaIdStr, out var oaid) ? oaid : null;
        var propietario = string.IsNullOrWhiteSpace(formPropietario) ? null : formPropietario.Trim();
        bool? bcp = string.IsNullOrWhiteSpace(formBcp) ? null : (formBcp.Trim().Equals("Sí", StringComparison.OrdinalIgnoreCase));
        var rto = string.IsNullOrWhiteSpace(formRTO) ? null : formRTO.Trim();
        var rpo = string.IsNullOrWhiteSpace(formRPO) ? null : formRPO.Trim();
        var clasifInfo = string.IsNullOrWhiteSpace(formClasificacionInformacion) ? null : formClasificacionInformacion.Trim();
        Guid? envId = Guid.TryParse(formEnvironmentIdStr, out var env) ? env : null;
        Guid? critId = Guid.TryParse(formCriticalityIdStr, out var cid) ? cid : null;
        Guid? catId = Guid.TryParse(formCategoryIdStr, out var cat) ? cat : null;
        Guid? manufId = Guid.TryParse(formManufacturerIdStr, out var mid) ? mid : null;
        Guid? devModelId = Guid.TryParse(formDeviceModelIdStr, out var dmid) ? dmid : null;

        if (editingId.HasValue && catalogosDisponibles)
        {
            var ent = await Db.Operaciones.FindAsync(editingId.Value);
            if (ent == null) { Toast.ShowToast("Registro no encontrado.", IITS.Services.ToastLevel.Warning); return; }
            var cambios = new List<string>();
            if (ent.Hostname != hostname) cambios.Add($"Hostname: {ent.Hostname ?? "-"} → {hostname}");
            if ((ent.Serial ?? "") != serial) cambios.Add($"Serial: {ent.Serial ?? "-"} → {serial ?? "-"}");
            if (ent.EstatusId != eid) cambios.Add($"Estatus: (cambió)");
            if (ent.OfficeId != officeId) cambios.Add($"Oficina: (cambió)");
            if (ent.AreaId != areaId) cambios.Add($"Área: (cambió)");
            if (ent.AlojamientoId != alojamientoId) cambios.Add($"Alojamiento: (cambió)");
            if ((ent.TipoDispositivo ?? "") != (formTipoDispositivo?.Trim() ?? "")) cambios.Add($"Tipo dispositivo: {ent.TipoDispositivo ?? "-"} → {formTipoDispositivo?.Trim() ?? "-"}");
            if ((ent.Funcion ?? "") != (formFuncion?.Trim() ?? "")) cambios.Add($"Función: {ent.Funcion ?? "-"} → {formFuncion?.Trim() ?? "-"}");
            if ((ent.TipoInfraestructura ?? "") != (formTipoInfraestructura?.Trim() ?? "")) cambios.Add($"Tipo infra: {ent.TipoInfraestructura ?? "-"} → {formTipoInfraestructura?.Trim() ?? "-"}");
            if ((ent.IP ?? "") != (formIP?.Trim() ?? "")) cambios.Add($"IP: {ent.IP ?? "-"} → {formIP?.Trim() ?? "-"}");
            if ((ent.SistemaOperativo ?? "") != (formSistemaOperativo?.Trim() ?? "")) cambios.Add($"SO: {ent.SistemaOperativo ?? "-"} → {formSistemaOperativo?.Trim() ?? "-"}");
            if ((ent.Host ?? "") != (formHost?.Trim() ?? "")) cambios.Add($"Host: {ent.Host ?? "-"} → {formHost?.Trim() ?? "-"}");
            if (ent.CantidadCPU != formCantidadCPU) cambios.Add($"Cant. CPU/VP: {ent.CantidadCPU} → {formCantidadCPU}");
            var detalleAudit = cambios.Count > 0 ? string.Join("; ", cambios) : hostname;
            ent.Hostname = hostname;
            ent.Serial = serial ?? "";
            ent.EstatusId = eid;
            ent.OfficeId = officeId;
            ent.AreaId = areaId;
            ent.AlojamientoId = alojamientoId;
            ent.OwnerAreaId = null;
            ent.Propietario = propietario;
            ent.BCP = bcp;
            ent.RTO = rto;
            ent.RPO = rpo;
            ent.ClasificacionInformacion = clasifInfo;
            ent.EnvironmentId = envId;
            ent.CriticalityId = critId;
            ent.CategoryId = catId;
            ent.ManufacturerId = manufId;
            ent.DeviceModelId = devModelId;
            ent.TipoDispositivo = string.IsNullOrWhiteSpace(formTipoDispositivo) ? null : formTipoDispositivo.Trim();
            ent.Funcion = string.IsNullOrWhiteSpace(formFuncion) ? null : formFuncion.Trim();
            ent.TipoInfraestructura = string.IsNullOrWhiteSpace(formTipoInfraestructura) ? null : formTipoInfraestructura.Trim();
            ent.Host = string.IsNullOrWhiteSpace(formHost) ? null : formHost.Trim();
            ent.RAM = string.IsNullOrWhiteSpace(formRAM) ? null : formRAM.Trim();
            ent.CantidadCPU = formCantidadCPU;
            ent.VelocidadCPU = string.IsNullOrWhiteSpace(formVelocidadCPU) ? null : formVelocidadCPU.Trim();
            ent.CapacidadDAS = string.IsNullOrWhiteSpace(formCapacidadDAS) ? null : formCapacidadDAS.Trim();
            ent.CapacidadSAN = string.IsNullOrWhiteSpace(formCapacidadSAN) ? null : formCapacidadSAN.Trim();
            ent.SistemaOperativo = string.IsNullOrWhiteSpace(formSistemaOperativo) ? null : formSistemaOperativo.Trim();
            ent.Firmware = string.IsNullOrWhiteSpace(formFirmware) ? null : formFirmware.Trim();
            ent.GarantiaExpira = garantiaExpira;
            ent.IP = string.IsNullOrWhiteSpace(formIP) ? null : formIP.Trim();
            ent.MAC = string.IsNullOrWhiteSpace(formMAC) ? null : formMAC.Trim();
            ent.Observaciones = string.IsNullOrWhiteSpace(formObservaciones) ? null : formObservaciones.Trim();
            await Db.SaveChangesAsync();
            await AuditLogService.RegistrarAsync("Operaciones", ent.Id, "Actualizar", detalleAudit, UserService.UserId);
            await AprobacionService.RegistrarAsync("Operaciones", ent.Id, "Por aprobar", "Modificación de tecnología", UserService.UserId);
            var cambiosHtml = cambios.Count > 0 ? string.Join("<br/>", cambios.Select(c => System.Net.WebUtility.HtmlEncode(c))) : null;
            try { await NotificarAprobadoresTecnologiaAsync(ent.Id, hostname, esModificacion: true, cambiosHtml: cambiosHtml); } catch { }
        }
        else
        {
            var id = Guid.NewGuid();
            var now = DateTime.UtcNow;
            if (catalogosDisponibles)
            {
                Db.Operaciones.Add(new IITS.Entities.Operacion
                {
                    Id = id,
                    Hostname = hostname,
                    Serial = serial,
                    EstatusId = eid,
                    CreatedAt = now,
                    OfficeId = officeId,
                    AreaId = areaId,
                    AlojamientoId = alojamientoId,
                    OwnerAreaId = null,
                    Propietario = propietario,
                    BCP = bcp,
                    RTO = rto,
                    RPO = rpo,
                    ClasificacionInformacion = clasifInfo,
                    EnvironmentId = envId,
                    CriticalityId = critId,
                    CategoryId = catId,
                    ManufacturerId = manufId,
                    DeviceModelId = devModelId,
                    TipoDispositivo = string.IsNullOrWhiteSpace(formTipoDispositivo) ? null : formTipoDispositivo.Trim(),
                    Funcion = string.IsNullOrWhiteSpace(formFuncion) ? null : formFuncion.Trim(),
                    TipoInfraestructura = string.IsNullOrWhiteSpace(formTipoInfraestructura) ? null : formTipoInfraestructura.Trim(),
                    Host = string.IsNullOrWhiteSpace(formHost) ? null : formHost.Trim(),
                    RAM = string.IsNullOrWhiteSpace(formRAM) ? null : formRAM.Trim(),
                    CantidadCPU = formCantidadCPU,
                    VelocidadCPU = string.IsNullOrWhiteSpace(formVelocidadCPU) ? null : formVelocidadCPU.Trim(),
                    CapacidadDAS = string.IsNullOrWhiteSpace(formCapacidadDAS) ? null : formCapacidadDAS.Trim(),
                    CapacidadSAN = string.IsNullOrWhiteSpace(formCapacidadSAN) ? null : formCapacidadSAN.Trim(),
                    SistemaOperativo = string.IsNullOrWhiteSpace(formSistemaOperativo) ? null : formSistemaOperativo.Trim(),
                    Firmware = string.IsNullOrWhiteSpace(formFirmware) ? null : formFirmware.Trim(),
                    GarantiaExpira = garantiaExpira,
                    IP = string.IsNullOrWhiteSpace(formIP) ? null : formIP.Trim(),
                    MAC = string.IsNullOrWhiteSpace(formMAC) ? null : formMAC.Trim(),
                    Observaciones = string.IsNullOrWhiteSpace(formObservaciones) ? null : formObservaciones.Trim()
                });
                await Db.SaveChangesAsync();
            }
            else
            {
                await Db.Database.ExecuteSqlRawAsync(
                    "INSERT INTO [Operaciones] ([Id], [Hostname], [Serial], [EstatusId], [CreatedAt]) VALUES ({0}, {1}, {2}, {3}, {4})",
                    id, hostname, serial, eid, now);
            }
            await AuditLogService.RegistrarAsync("Operaciones", id, "Crear", hostname, UserService.UserId);
            await AprobacionService.RegistrarAsync("Operaciones", id, "Por aprobar", "Alta de tecnología", UserService.UserId);
            try { await NotificarAprobadoresTecnologiaAsync(id, hostname); } catch { }
        }
        CerrarModal();
        await Cargar();
    }

    private async Task NotificarAprobadoresTecnologiaAsync(Guid entidadId, string hostname, bool esModificacion = false, string? cambiosHtml = null)
    {
        var aprobadores = await AprobacionPermisoService.GetApproversForModuloAsync("Operaciones");
        var accion = esModificacion ? "Modificación de tecnología" : "Alta de tecnología";
        var subject = $"IITS: Solicitud por aprobar - Tecnología - {hostname}";
        var body = "<p>Se ha registrado una solicitud pendiente de aprobación.</p>";
        body += "<p><strong>Módulo:</strong> Tecnología<br/><strong>Acción:</strong> " + System.Net.WebUtility.HtmlEncode(accion) + "<br/><strong>Hostname:</strong> " + System.Net.WebUtility.HtmlEncode(hostname) + "</p>";
        if (esModificacion && !string.IsNullOrEmpty(cambiosHtml))
            body += "<p><strong>Detalle de cambios (antes → después):</strong></p><p style=\"margin-left:1em;font-family:monospace;\">" + cambiosHtml + "</p>";
        var baseUrl = Config["App:BaseUrl"]?.TrimEnd('/');
        if (!string.IsNullOrEmpty(baseUrl))
            body += "<p><a href=\"" + System.Net.WebUtility.HtmlEncode(baseUrl) + "/auditoria/operaciones\" style=\"color:#00338d;\">Ir a IITS para aprobar o rechazar</a></p>";
        foreach (var u in aprobadores)
        {
            if (string.IsNullOrWhiteSpace(u.Email)) continue;
            try { await EmailOutboxService.EnqueueAsync(u.Email, subject, body); } catch { /* no fallar el flujo */ }
        }
    }

    private async Task Eliminar(Guid id) { var e = await Db.Operaciones.FindAsync(id); if (e != null) { Db.Operaciones.Remove(e); await Db.SaveChangesAsync(); await Cargar(); } }
