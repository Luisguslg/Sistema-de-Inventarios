    private void AbrirAgregarFabricante() { newFabricanteName = ""; mostrarModalFabricante = true; }
    private void CerrarAgregarFabricante() { mostrarModalFabricante = false; newFabricanteName = ""; }
    private async Task GuardarAgregarFabricante()
    {
        if (string.IsNullOrWhiteSpace(newFabricanteName)) return;
        var name = newFabricanteName.Trim();
        if (vendorsList.Any(v => string.Equals(v.Name, name, StringComparison.OrdinalIgnoreCase))) { Toast.ShowToast("Ese fabricante ya existe.", IITS.Services.ToastLevel.Warning); return; }
        var id = Guid.NewGuid();
        Db.Vendors.Add(new IITS.Entities.Vendor { Id = id, Name = name });
        await Db.SaveChangesAsync();
        vendorsList = await Db.Vendors.AsNoTracking().OrderBy(v => v.Name).ToListAsync();
        formManufacturerIdStr = id.ToString();
        CerrarAgregarFabricante();
        Toast.ShowToast("Fabricante agregado.", IITS.Services.ToastLevel.Success);
    }

    private void AbrirAgregarModelo() { newModeloName = ""; newModeloFabricanteIdStr = formManufacturerIdStr ?? ""; mostrarModalModelo = true; }
    private void CerrarAgregarModelo() { mostrarModalModelo = false; newModeloName = ""; }
    private async Task GuardarAgregarModelo()
    {
        if (string.IsNullOrWhiteSpace(newModeloName) || !Guid.TryParse(newModeloFabricanteIdStr, out var manufId)) { Toast.ShowToast("Seleccione fabricante e ingrese nombre.", IITS.Services.ToastLevel.Warning); return; }
        var name = newModeloName.Trim();
