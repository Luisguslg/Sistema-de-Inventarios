    private void OnFabricanteCambio()
    {
        if (!Guid.TryParse(formManufacturerIdStr, out var mid)) return;
        var vendor = vendorsList.FirstOrDefault(v => v.Id == mid);
        if (vendor?.Name == "N/A")
        {
            var modeloNa = deviceModelsList.FirstOrDefault(d => d.ManufacturerId == mid && d.Name == "N/A");
            if (modeloNa != null) formDeviceModelIdStr = modeloNa.Id.ToString();
        }
    }

    private void CerrarAgregarCatalogo()
    {
        addingCatalogKind = null;
        newCatalogName = "";
        onCatalogAdded = null;
    }

    private async Task KeydownAgregarCatalogo(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await GuardarAgregarCatalogo();
    }

    private async Task GuardarAgregarCatalogo()
    {
        if (string.IsNullOrWhiteSpace(newCatalogName) || string.IsNullOrEmpty(addingCatalogKind)) return;
        var name = newCatalogName.Trim();
        var existingNames = await Db.CatalogItems.Where(c => c.Kind == addingCatalogKind).Select(c => c.Name).ToListAsync();
        if (existingNames.Any(n => string.Equals(n.Trim(), name, StringComparison.OrdinalIgnoreCase)))
        {
            Toast.ShowToast("Ese valor ya existe (no se permiten duplicados aunque cambien mayúsculas)", IITS.Services.ToastLevel.Warning);
            return;
        }
        Db.CatalogItems.Add(new IITS.Entities.CatalogItem { Id = Guid.NewGuid(), Kind = addingCatalogKind, Name = name });
        await Db.SaveChangesAsync();
        await CargarCatalogItems();
        onCatalogAdded?.Invoke(name);
        CerrarAgregarCatalogo();
        Toast.ShowToast("Agregado. Puede usarlo en el select.", IITS.Services.ToastLevel.Success);
    }

