@inherits ToastBase
@inject ToastService toastService



<div class="toast @(IsVisible ? "toast-visible" : null) @BackgroundCssClass">
    <button class="delete" @onclick="@(() => toastService.HideToast())"></button>
    <div class="toast-icon">
        <i class="mdi mdi-@IconCssClass" aria-hidden="true"></i>
    </div>
    <div class="toast-body">
        <h5>@Heading</h5>
        <p>@((MarkupString)Message)</p>
    </div>
</div>