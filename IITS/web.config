<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS (VECCSAPP10): Production. Connection string y SMTP en variables de entorno
  (mismo criterio que Sumando Valor). Server=host,puerto fuerza TCP y evita Named Pipes.
  Si la instancia KPMGDV usa otro puerto, cambia 61057 en ConnectionStrings__IITS.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <!-- [SEC-AUDIT]: Mitigación para CWE-200 / CWE-16 - Se suprime la cabecera Server que
           exponía la versión de Microsoft-IIS (información de plataforma aprovechable en
           reconocimiento previo a ataques dirigidos). removeServerHeader requiere IIS 10+. -->
      <security>
        <requestFiltering removeServerHeader="true" />
      </security>
      <!-- [SEC-AUDIT]: Mitigación para CWE-200 - Se elimina la cabecera X-Powered-By que
           divulgaba el framework y versión de ASP.NET al cliente. Las cabeceras adicionales
           de seguridad (CSP, X-Frame-Options, X-Content-Type-Options, etc.) son emitidas
           por el middleware de ASP.NET Core definido en Program.cs, garantizando cobertura
           tanto en IIS como en Kestrel sin duplicación. -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
        </customHeaders>
      </httpProtocol>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\IITS.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess"
                  forwardWindowsAuthToken="true">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <environmentVariable name="ConnectionStrings__IITS" value="Server=VECCSAPP10,61057;Database=IITSN;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=True;" />
          <environmentVariable name="Auth__SuperAdminUsername" value="VE\luisperdomo" />
          <environmentVariable name="Email__Mode" value="Smtp" />
          <environmentVariable name="Email__From" value="IITS &lt;Ve-iits@apprelay.kpmg.com&gt;" />
          <environmentVariable name="Email__SmtpServer" value="goemairs.go.kworld.kpmg.com" />
          <environmentVariable name="Email__Port" value="25" />
          <environmentVariable name="Email__EnableSsl" value="false" />
          <!-- Ruta anterior a la app (si la URL es http://servidor/ALGO/..., pon aquí ALGO) -->
          <environmentVariable name="PathBase" value="IITSN" />
          <!-- URL base para enlaces en correos. Debe ser la URL pública donde los usuarios acceden (no el nombre del servidor). -->
          <environmentVariable name="App__BaseUrl" value="https://desarrollos.ve.kworld.kpmg.com/IITSN" />
        </environmentVariables>
      </aspNetCore>
    </system.webServer>
  </location>
</configuration>
